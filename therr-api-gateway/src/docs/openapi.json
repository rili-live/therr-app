  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key obtained from the Therr dashboard. Format: `therr_sk_<prefix>_<secret>`"
      }
    },
    "schemas": {
      "CreateSpaceRequest": {
        "type": "object",
        "required": ["fromUserId", "message", "latitude", "longitude"],
        "properties": {
          "fromUserId": {
            "type": "string",
            "format": "uuid",
            "description": "Your user ID"
          },
          "message": {
            "type": "string",
            "description": "Space description / about text"
          },
          "notificationMsg": {
            "type": "string",
            "maxLength": 100,
            "description": "Short notification message (displayed in feeds)"
          },
          "latitude": {
            "type": "number",
            "description": "Latitude of the space location"
          },
          "longitude": {
            "type": "number",
            "description": "Longitude of the space location"
          },
          "radius": {
            "type": "number",
            "description": "Radius in meters (default: 10). Required if polygonCoords not provided."
          },
          "polygonCoords": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "number"
              },
              "minItems": 2,
              "maxItems": 2
            },
            "description": "Array of [latitude, longitude] pairs defining the space boundary. Required if radius not provided."
          },
          "category": {
            "type": "string",
            "description": "Business category (e.g., 'restaurant', 'bar', 'shop')"
          },
          "isPublic": {
            "type": "boolean",
            "default": false,
            "description": "Whether the space is publicly visible"
          },
          "isDraft": {
            "type": "boolean",
            "default": false,
            "description": "Whether this is a draft listing"
          },
          "organizationId": {
            "type": "string",
            "format": "uuid",
            "description": "Link space to an organization. You must have admin or manager access to the organization."
          },
          "addressReadable": {
            "type": "string",
            "description": "Human-readable address"
          },
          "addressStreetAddress": {
            "type": "string"
          },
          "addressRegion": {
            "type": "string"
          },
          "addressLocality": {
            "type": "string"
          },
          "postalCode": {
            "type": "integer"
          },
          "phoneNumber": {
            "type": "string",
            "maxLength": 24
          },
          "businessEmail": {
            "type": "string",
            "format": "email"
          },
          "websiteUrl": {
            "type": "string",
            "format": "uri"
          },
          "menuUrl": {
            "type": "string",
            "format": "uri"
          },
          "orderUrl": {
            "type": "string",
            "format": "uri"
          },
          "reservationUrl": {
            "type": "string",
            "format": "uri"
          },
          "priceRange": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "description": "Price range (1-5)"
          },
          "openingHours": {
            "type": "object",
            "description": "Opening hours by day of week"
          },
          "hashTags": {
            "type": "string",
            "description": "Comma-separated hash tags"
          },
          "medias": {
            "type": "array",
            "description": "Array of media objects to attach",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "UpdateSpaceRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Space description / about text"
          },
          "notificationMsg": {
            "type": "string",
            "maxLength": 100
          },
          "category": {
            "type": "string"
          },
          "isPublic": {
            "type": "boolean"
          },
          "isDraft": {
            "type": "boolean"
          },
          "addressReadable": {
            "type": "string"
          },
          "addressStreetAddress": {
            "type": "string"
          },
          "addressRegion": {
            "type": "string"
          },
          "addressLocality": {
            "type": "string"
          },
          "postalCode": {
            "type": "integer"
          },
          "phoneNumber": {
            "type": "string",
            "maxLength": 24
          },
          "businessEmail": {
            "type": "string",
            "format": "email"
          },
          "websiteUrl": {
            "type": "string",
            "format": "uri"
          },
          "menuUrl": {
            "type": "string",
            "format": "uri"
          },
          "orderUrl": {
            "type": "string",
            "format": "uri"
          },
          "reservationUrl": {
            "type": "string",
            "format": "uri"
          },
          "priceRange": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "openingHours": {
            "type": "object"
          },
          "thirdPartyRatings": {
            "type": "object",
            "description": "Third-party rating data (e.g., Google, Yelp)"
          },
          "hashTags": {
            "type": "string"
          },
          "medias": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Space": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "fromUserId": {
            "type": "string",
            "format": "uuid"
          },
          "organizationId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "message": {
            "type": "string"
          },
          "notificationMsg": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "radius": {
            "type": "number"
          },
          "region": {
            "type": "string",
            "description": "Country code"
          },
          "isPublic": {
            "type": "boolean"
          },
          "isDraft": {
            "type": "boolean"
          },
          "addressReadable": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "businessEmail": {
            "type": "string"
          },
          "websiteUrl": {
            "type": "string"
          },
          "menuUrl": {
            "type": "string"
          },
          "orderUrl": {
            "type": "string"
          },
          "reservationUrl": {
            "type": "string"
          },
          "priceRange": {
            "type": "integer"
          },
          "openingHours": {
            "type": "object"
          },
          "hashTags": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SpaceDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Space"
          },
          {
            "type": "object",
            "properties": {
              "media": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    }
                  }
                }
              },
              "user": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "userName": {
                    "type": "string"
                  }
                }
              },
              "rating": {
                "type": "object"
              }
            }
          }
        ]
      },
      "SpaceSearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Space"
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "itemsPerPage": {
                "type": "integer"
              },
              "pageNumber": {
                "type": "integer"
              }
            }
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "itemsPerPage": {
                "type": "integer"
              },
              "pageNumber": {
                "type": "integer"
              }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "userName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "isBusinessAccount": {
            "type": "boolean"
          }
        }
      },
