{
  "openapi": "3.0.3",
  "info": {
    "title": "Therr Public API",
    "version": "1.0.0",
    "description": "The Therr Public API enables business listing management agencies and developers to programmatically manage spaces (business listings), search content, and access platform data.\n\n## Authentication\n\nAll API requests require an API key passed via the `x-api-key` header.\n\n**Getting an API key:**\n1. Sign up for a dashboard subscription at [dashboard.therr.com](https://dashboard.therr.com)\n2. Navigate to Settings and generate an API key\n3. Copy the key immediately - it will only be shown once\n\n**Using the key:**\n```\ncurl -H 'x-api-key: therr_sk_...' https://api.therr.com/v1/maps-service/spaces/search\n```\n\n## Rate Limits\n\n- **100 requests per minute** per API key\n- Rate limit headers are returned with every response: `X-RateLimit-Limit`, `X-RateLimit-Remaining`, `X-RateLimit-Reset`\n- When exceeded, the API returns `429 Too Many Requests`\n\n## Organization-Based Access\n\nAPI keys inherit the permissions of the user who created them. If you belong to an organization with admin or manager access, you can create and update spaces belonging to that organization.\n\n## Errors\n\nThe API uses standard HTTP status codes:\n- `200` - Success\n- `201` - Created\n- `400` - Bad request (validation error)\n- `401` - Invalid or missing API key\n- `403` - Insufficient permissions\n- `404` - Resource not found\n- `429` - Rate limit exceeded\n- `500` - Internal server error",
    "contact": {
      "name": "Therr Support",
      "url": "https://www.therr.com"
    }
  },
  "servers": [
    {
      "url": "https://api.therr.com/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Spaces",
      "description": "Business listings and location pages. Spaces represent persistent locations such as restaurants, shops, offices, or points of interest."
    },
    {
      "name": "Moments",
      "description": "Location-tagged posts and ephemeral content."
    },
    {
      "name": "Events",
      "description": "Time-bound events at locations."
    },
    {
      "name": "Users",
      "description": "User profiles and search."
    },
    {
      "name": "Reactions",
      "description": "Engagement data such as likes, ratings, and check-ins."
    },
    {
      "name": "API Keys",
      "description": "Manage your API keys."
    }
  ],
  "paths": {
    "/maps-service/spaces": {
      "post": {
        "tags": ["Spaces"],
        "summary": "Create a space",
        "description": "Creates a new business listing / space. Requires latitude, longitude, and a message. Optionally link it to your organization via `organizationId`.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSpaceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Space created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Space"
                }
              }
            }
          },
          "400": {
            "description": "Validation error or duplicate post"
          },
          "403": {
            "description": "Insufficient permissions for the specified organization"
          }
        }
      }
    },
    "/maps-service/spaces/{spaceId}": {
      "put": {
        "tags": ["Spaces"],
        "summary": "Update a space",
        "description": "Updates an existing space. You must be the space owner, or have ORGANIZATIONS_ADMIN/ORGANIZATIONS_MANAGER access to the space's organization.",
        "parameters": [
          {
            "name": "spaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSpaceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Space updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Space"
                }
              }
            }
          },
          "403": {
            "description": "Not authorized to update this space"
          },
          "404": {
            "description": "Space not found"
          }
        }
      },
      "get": {
        "tags": ["Spaces"],
        "summary": "Get a space by ID",
        "parameters": [
          {
            "name": "spaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Space details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Space"
                }
              }
            }
          },
          "404": {
            "description": "Space not found"
          }
        }
      }
    },
    "/maps-service/spaces/{spaceId}/details": {
      "post": {
        "tags": ["Spaces"],
        "summary": "Get full space details",
        "description": "Returns space details with optional media and user information.",
        "parameters": [
          {
            "name": "spaceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "withMedia": {
                    "type": "boolean",
                    "description": "Include associated media"
                  },
                  "withUser": {
                    "type": "boolean",
                    "description": "Include owner user information"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Full space details with media and user data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpaceDetails"
                }
              }
            }
          }
        }
      }
    },
    "/maps-service/spaces/search": {
      "post": {
        "tags": ["Spaces"],
        "summary": "Search spaces",
        "description": "Search for spaces by location. Returns spaces within proximity of the given coordinates.",
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "itemsPerPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpaceSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/maps-service/spaces/search/me": {
      "post": {
        "tags": ["Spaces"],
        "summary": "Search your spaces",
        "description": "Returns spaces owned by you or belonging to your organizations.",
        "parameters": [
          {
            "name": "itemsPerPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Your spaces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpaceSearchResponse"
                }
              }
            }
          }
        }
      }
    },
    "/maps-service/spaces/list": {
