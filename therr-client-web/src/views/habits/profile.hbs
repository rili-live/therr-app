<!DOCTYPE html>
<html lang="en-US">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel="canonical" href="{{canonicalUrl}}">
    <meta name="description" content="{{description}}">
    <meta name="author" content="Therr Inc.">
    <meta property="og:site_name" content="Friends with Habits">
    <meta property="og:type" content="profile">
    <meta property="og:url" content="{{canonicalUrl}}">
    <meta property="og:title" content="{{title}}">
    <meta property="og:description" content="{{description}}">
    {{#if hasAvatar}}<meta property="og:image" content="{{avatarUri}}">{{/if}}
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{title}}">
    <meta name="twitter:description" content="{{description}}">
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;600;800&display=swap">
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon-habits.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/images/favicon-habits-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/images/favicon-habits-16x16.png">
    <style>
        :root {
            --habits-navy: #102a43;
            --habits-coral: #ff6b35;
            --habits-coral-dark: #e0521e;
            --habits-cream: #fff8f3;
            --habits-text: #243b53;
            --habits-text-muted: #627d98;
            --habits-border: #d9e2ec;
        }
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            margin: 0;
            padding: 0;
            font-family: 'Lexend', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            font-size: 16px;
            line-height: 1.6;
            color: var(--habits-text);
            background: var(--habits-cream);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        a { color: var(--habits-coral-dark); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .container { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
        header.site-header {
            padding: 1.25rem 0;
            border-bottom: 1px solid var(--habits-border);
            background: #fff;
        }
        header.site-header .brand {
            font-weight: 800;
            font-size: 1.125rem;
            color: var(--habits-navy);
            letter-spacing: -0.01em;
        }
        .profile {
            padding: 3rem 0 2.5rem;
            text-align: center;
        }
        .profile .avatar {
            display: block;
            width: 144px;
            height: 144px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 auto 1.25rem;
            background: var(--habits-border);
            border: 4px solid #fff;
            box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
        }
        .profile .avatar-placeholder {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 144px;
            height: 144px;
            border-radius: 50%;
            background: var(--habits-coral);
            color: #fff;
            font-weight: 800;
            font-size: 3rem;
            margin: 0 auto 1.25rem;
            border: 4px solid #fff;
            box-shadow: 0 4px 16px rgba(16, 42, 67, 0.08);
        }
        .profile h1 {
            font-size: 2rem;
            font-weight: 800;
            line-height: 1.2;
            color: var(--habits-navy);
            margin: 0 0 0.25rem;
            letter-spacing: -0.02em;
            word-break: break-word;
        }
        .profile .handle {
            color: var(--habits-text-muted);
            font-size: 1rem;
            margin: 0 0 1rem;
        }
        .profile .bio {
            color: var(--habits-text);
            font-size: 1rem;
            margin: 1rem auto 0;
            max-width: 540px;
            white-space: pre-wrap;
        }
        section.cross-promo {
            padding: 2.5rem 0;
            border-top: 1px solid var(--habits-border);
            text-align: center;
        }
        section.cross-promo .label {
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--habits-text-muted);
            margin: 0 0 1rem;
        }
        section.cross-promo .therr-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.625rem;
            padding: 0.875rem 1.5rem;
            background: #fff;
            color: var(--habits-navy);
            font-weight: 600;
            font-size: 1rem;
            border-radius: 999px;
            border: 1px solid var(--habits-border);
            transition: border-color 0.15s ease, transform 0.15s ease;
        }
        section.cross-promo .therr-cta:hover {
            border-color: var(--habits-navy);
            text-decoration: none;
            transform: translateY(-1px);
        }
        section.cross-promo .therr-cta img {
            width: 24px;
            height: 24px;
            display: block;
        }
        footer.site-footer {
            padding: 2rem 0 3rem;
            border-top: 1px solid var(--habits-border);
            background: #fff;
            text-align: center;
            color: var(--habits-text-muted);
            font-size: 0.875rem;
        }
        footer.site-footer .footer-links { margin-bottom: 0.75rem; }
        footer.site-footer .footer-links a {
            margin: 0 0.5rem;
            color: var(--habits-text-muted);
        }
        @media (min-width: 640px) {
            .profile { padding: 4rem 0 3rem; }
            .profile h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>
    <header class="site-header">
        <div class="container">
            <a class="brand" href="/" style="color: var(--habits-navy);">Friends with Habits</a>
        </div>
    </header>

    <main>
        <section class="profile">
            <div class="container">
                {{#if hasAvatar}}
                    <img class="avatar" src="{{avatarUri}}" alt="{{displayName}}">
                {{else}}
                    <span class="avatar-placeholder" aria-hidden="true">{{firstInitial}}</span>
                {{/if}}
                <h1>{{displayName}}</h1>
                <p class="handle">&#64;{{userName}}</p>
                {{#if hasBio}}<p class="bio">{{bio}}</p>{{/if}}
            </div>
        </section>

        {{#if hasTherrAccount}}
        <section class="cross-promo">
            <div class="container">
                <p class="label">Same person, more places</p>
                <a class="therr-cta" href="{{therrProfileUrl}}" rel="noopener">
                    <img src="/assets/images/therr-email-logo.svg" alt="" aria-hidden="true">
                    <span>Find me on the Therr app</span>
                </a>
            </div>
        </section>
        {{/if}}
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-links">
                <a href="/privacy-policy">Privacy Policy</a>
                <a href="/terms-of-service">Terms of Service</a>
            </div>
            <div>&copy; Therr Inc. &middot; Part of the Therr family of apps</div>
        </div>
    </footer>
</body>
</html>
