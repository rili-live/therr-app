{
  "extends": "../../tsconfig.service.json",
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "moduleTypes": {
      "**/*.ts": "cjs"
    }
  },
  "compilerOptions": {
    "target": "es6",
    "baseUrl": ".",
    "rootDir": ".",
    "typeRoots": ["../../node_modules/@types", "typings"],
    "types": ["node", "mocha", "chai", "sinon", "express"],
    "paths": {
      "therr-public-library/therr-styles/*": ["../../therr-public-library/therr-styles/*"],
      "therr-js-utilities/*": ["../../therr-public-library/therr-js-utilities/lib/*"]
    }
  },
  "files": [
    "src/app.d.ts",
    "src/unit_test.d.ts"
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "../../node_modules/**/*.*"
  ],
  "compileOnSave": false
}
