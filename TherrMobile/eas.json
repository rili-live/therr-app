{
  "cli": {
    "version": ">= 15.0.0",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "therr-internal": {
      "distribution": "store",
      "environment": "production",
      "android": {
        "image": "latest",
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease",
        "credentialsSource": "remote"
      },
      "autoSubmit": true
    }
  },
  "submit": {
    "therr-internal": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": true
      }
    }
  }
}
