{
  "name": "Therr",
  "version": "0.0.6",
  "private": true,
  "scripts": {
    "android": "export $(cat .env | xargs) && ./node_modules/.bin/react-native run-android",
    "android:clean": "pushd android && rm -rf app/.cxx app/build app/build/generated/autolinking .gradle build && ./gradlew clean; popd",
    "android:clean:cache": "pushd android && rm -rf app/.cxx app/build/generated/autolinking app/build/intermediates/cxx app/build/intermediates/cmake; popd",
    "android:device": "export $(cat .env | xargs) && adb reverse tcp:7770 tcp:7770 && adb reverse tcp:7743 tcp:7743 && adb reverse tcp:8081 tcp:8081 && ./node_modules/.bin/react-native run-android",
    "android:emulator": "emulator -avd Pixel_9 -no-snapshot-load &>/dev/null & echo 'Emulator starting...'",
    "android:log": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "android:logkitty": "export $(cat .env | xargs) && ./node_modules/.bin/react-native log-android",
    "android:deps": "pushd android && ./gradlew :app:dependencies && popd",
    "build:dev": "echo \"Error: no dev build for mobile app\" && exit 0",
    "build:android": "npm run build:release:apk",
    "build:ios": "npm run ios:bundle:release",
    "build:release": "export $(cat .env | xargs) && pushd android && ./gradlew bundleRelease && popd",
    "build:release:apk": "export $(cat .env | xargs) && pushd android && ./gradlew assembleRelease && popd",
    "build:release:ipa": "export $(cat .env | xargs) && ./node_modules/.bin/react-native run-ios --configuration Release",
    "clean": "npm run clean:env && rm -rf $TMPDIR/react-native-packager-cache-* && rm -rf $TMPDIR/metro-bundler-cache-* && rm -rf node_modules/ && npm cache clean --force && npm install && npm start -- --reset-cache",
    "clean:env": "rm -rf node_modules/.cache/babel-loader/*",
    "env:export": "export $(cat .env | xargs)",
    "getSHA": "pushd android && ./gradlew signingReport; popd",
    "ios": "rm -rf node_modules/.cache/babel-loader/*, && npm run ios:bundle && ./node_modules/.bin/react-native run-ios --scheme 'Therr_Debug'",
    "ios:clean": "rm -rf ~/Library/Caches/CocoaPods && rm -rf ./ios/Pods && rm -rf ~/Library/Developer/Xcode/DerivedData/* && rm -rf /Volumes/Samsung_T5/imac/Xcode/DerivedData/* && npm run ios:pod:install",
    "ios:bundle": "./node_modules/.bin/react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --assets-dest ./ios",
    "ios:bundle:release": "./node_modules/.bin/react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --assets-dest ./ios --dev=false --platform ios",
    "ios:pod:install": "pushd ios; pod install; popd",
    "ios:pod:update": "pushd ios && pod install --repo-update; popd",
    "ios:clean:simulators": "xcrun simctl delete unavailable",
    "react-devtools": "./node_modules/.bin/react-devtools",
    "start": "./node_modules/.bin/react-native start",
    "test": "../node_modules/.bin/jest --no-cache",
    "test:update": "../node_modules/.bin/jest -u",
    "test:watch": "../node_modules/.bin/jest --watch",
    "test:coverage": "../node_modules/.bin/jest --coverage",
    "lint": "../node_modules/.bin/eslint . --ext .js,.jsx,.ts,.tsx ./",
    "lint:fix": "../node_modules/.bin/eslint --ext .js,.jsx,.ts,.tsx --fix ./",
    "postinstall": "patch-package",
    "app:uninstall": "adb uninstall app.therrmobile",
    "android:reset": "adb uninstall app.therrmobile || true; adb shell pm trim-caches 999999999999 || true; export $(cat .env | xargs) && ./node_modules/.bin/react-native run-android",
    "troubleshoot:android:stopGradle": "pushd android; ./gradlew --stop; popd",
    "troubleshoot:android:clean": "npm run android:clean",
    "perf:reset": "./_scripts/perf-capture.sh reset",
    "perf:snapshot": "./_scripts/perf-capture.sh snapshot"
  },
  "dependencies": {
    "@callstack/react-theme-provider": "^3.0.9",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@invertase/react-native-apple-authentication": "^2.5.0",
    "@logrocket/react-native": "^1.59.4",
    "@notifee/react-native": "^7.9.0",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-firebase/analytics": "^21.6.1",
    "@react-native-firebase/app": "^21.6.1",
    "@react-native-firebase/auth": "^21.6.1",
    "@react-native-firebase/crashlytics": "^21.6.1",
    "@react-native-firebase/messaging": "^21.6.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@reduxjs/toolkit": "^2.5.0",
    "@shopify/flash-list": "^1.8.3",
    "deprecated-react-native-prop-types": "^5.0.0",
    "lottie-react-native": "^7.3.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-actions-sheet": "^0.9.8",
    "react-native-autolink": "^3.0.0",
    "react-native-background-fetch": "^4.2.8",
    "react-native-background-geolocation": "^4.19.3",
    "react-native-blob-util": "^0.19.11",
    "react-native-bootsplash": "^6.3.11",
    "react-native-config": "^1.6.1",
    "react-native-contacts": "^8.0.10",
    "react-native-country-picker-modal": "^2.0.0",
    "react-native-date-picker": "^5.0.13",
    "react-native-device-info": "^10.14.0",
    "react-native-dotenv": "^3.4.11",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-keyboard-controller": "^1.21.5",
    "react-native-keychain": "^9.2.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-map-link": "^2.11.4",
    "react-native-maps": "1.27.2",
    "react-native-mmkv": "^3.3.3",
    "react-native-pager-view": "^6.9.1",
    "react-native-paper": "^5.15.0",
    "react-native-permissions": "^5.5.1",
    "react-native-phone-input": "^1.3.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.1.0",
    "react-native-screens": "^4.24.0",
    "react-native-spotlight-tour": "^3.0.1",
    "react-native-svg": "^15.15.4",
    "react-native-tab-view": "^3.3.0",
    "react-native-toast-message": "^2.1.5",
    "react-native-vector-icons": "^10.3.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "^0.8.1",
    "react-native-youtube-iframe": "^1.4.0",
    "react-redux": "^9.2.0",
    "react-test-renderer": "19.2.0",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "rn-placeholder": "^3.0.3",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.6",
    "@react-native/eslint-config": "^0.83.6",
    "@react-native/metro-config": "0.83.6",
    "@react-native/normalize-colors": "^0.83.6",
    "@react-native/typescript-config": "0.83.6",
    "@tsconfig/react-native": "^3.0.8",
    "@types/react": "^19.2.0",
    "@types/react-native-dotenv": "^0.2.2",
    "@types/rn-fetch-blob": "^1.2.7",
    "@welldone-software/why-did-you-render": "^7.0.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-transform-inline-environment-variables": "^0.4.3",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint-plugin-jest": "^28.14.0",
    "patch-package": "^6.5.1",
    "react-devtools": "^6.1.1",
    "reactotron-react-native": "^5.1.18"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rn-placeholder": {
      "react": "$react",
      "react-native": "$react-native"
    },
    "react-native-country-picker-modal": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "rnpm": {
    "assets": [
      "resources/fonts"
    ]
  }
}
