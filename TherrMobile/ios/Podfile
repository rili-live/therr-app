# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# IOS_VERSION = min_ios_version_supported
IOS_VERSION = '15.1'

platform :ios, IOS_VERSION
prepare_react_native_project!

# Firebase v10+ uses Swift modules, requiring frameworks for proper header generation
use_frameworks! :linkage => :static
$RNFirebaseAsStaticFramework = true

target 'Therr' do
  project 'Therr', 'Therr_Debug' => :debug, 'Debug' => :debug, 'Therr_Release' => :release, 'Release' => :release
  # React Native Maps with Google Maps support
  rn_maps_path = '../node_modules/react-native-maps'
  pod 'react-native-maps', :path => rn_maps_path
  pod 'react-native-google-maps', :path => rn_maps_path
  pod 'GoogleMaps', '8.4.0'
  pod 'Google-Maps-iOS-Utils', '5.0.0'

  # Google SSO
  pod 'GoogleSignIn', '~> 9.0'

  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Permissions
  permissions_path = '../node_modules/react-native-permissions/ios'
  pod 'Permission-Camera', :path => "#{permissions_path}/Camera"
  pod 'Permission-LocationAccuracy', :path => "#{permissions_path}/LocationAccuracy"
  pod 'Permission-LocationAlways', :path => "#{permissions_path}/LocationAlways"
  pod 'Permission-LocationWhenInUse', :path => "#{permissions_path}/LocationWhenInUse"
  pod 'Permission-MediaLibrary', :path => "#{permissions_path}/MediaLibrary"
  pod 'Permission-Microphone', :path => "#{permissions_path}/Microphone"
  pod 'Permission-Notifications', :path => "#{permissions_path}/Notifications"
  pod 'Permission-PhotoLibrary', :path => "#{permissions_path}/PhotoLibrary"

  # Third-party pods (BVLinearGradient and react-native-blob-util are autolinked)
  # Firebase pods with modular headers for Swift compatibility
  pod 'Firebase', :modular_headers => true
  pod 'Firebase/Analytics', :modular_headers => true
  pod 'Firebase/Auth', :modular_headers => true
  pod 'FirebaseAuth', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseAuthInterop', :modular_headers => true
  pod 'FirebaseAppCheckInterop', :modular_headers => true
  pod 'FirebaseCrashlytics', :modular_headers => true
  pod 'FirebaseMessaging', :modular_headers => true
  pod 'FirebaseSessions', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'nanopb', :modular_headers => true
  

  target 'TherrTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix RCT-Folly New.h for Xcode 26+ clang compatibility
    # __has_builtin returns 1 but Folly checks >= 201802L, forcing a library operator
    # path that newer clang can't resolve. Patch to use builtin operators directly.
    folly_new_h = File.join(__dir__, 'Pods', 'RCT-Folly', 'folly', 'lang', 'New.h')
    if File.exist?(folly_new_h)
      File.chmod(0644, folly_new_h)
      content = File.read(folly_new_h)
      content.gsub!(/constexpr auto op_new_builtin_ =\n\s+FOLLY_HAS_BUILTIN\(__builtin_operator_new\)[^;]*;/, 'constexpr auto op_new_builtin_ = true;')
      content.gsub!(/constexpr auto op_del_builtin_ =\n\s+FOLLY_HAS_BUILTIN\(__builtin_operator_del[^)]*\)[^;]*;/, 'constexpr auto op_del_builtin_ = true;')
      File.write(folly_new_h, content)
    end

    # Fix react-native-permissions __has_include with use_frameworks! :linkage => :static
    # Permission handler headers are in separate framework modules, so RNPermissions
    # can't find them via __has_include without explicit header search paths.
    permissions_path = File.join(Pod::Config.instance.installation_root, '..', 'node_modules', 'react-native-permissions', 'ios')
    permission_pods = %w[Camera LocationAccuracy LocationAlways LocationWhenInUse MediaLibrary Microphone Notifications PhotoLibrary]

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
       config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = IOS_VERSION
       config.build_settings["ONLY_ACTIVE_ARCH"] = "NO"
       config.build_settings['ENABLE_BITCODE'] = 'NO'
      #  config.build_settings["ONLY_ACTIVE_ARCH"] = "YES"
      end

      if target.name == 'RNPermissions'
        target.build_configurations.each do |config|
          permission_pods.each do |handler|
            config.build_settings['HEADER_SEARCH_PATHS'] ||= '$(inherited)'
            config.build_settings['HEADER_SEARCH_PATHS'] += " \"#{permissions_path}/#{handler}\""
          end
        end
      end
    end
  end
end
